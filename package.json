{
  "name": "otchetiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "report": "node src/reporting.mjs run",
    "report:april:sheets": "node src/reporting.mjs run --source bitrix --from 2026-04-01 --to 2026-04-14 --google-sheets",
    "report:auto:sheets": "node src/reporting.mjs run --source bitrix --month-current --calls-today --google-sheets",
    "report:2h:sheets": "node src/reporting.mjs run --source bitrix --month-current --calls-today --google-sheets",
    "report:full-month:sheets": "node src/reporting.mjs run --source bitrix --month-current --google-sheets",
    "sheets": "node src/reporting.mjs run --skip-bitrix --skip-skorozvon --google-sheets"
  },
  "dependencies": {
    "googleapis": "^171.4.0"
  }
}
